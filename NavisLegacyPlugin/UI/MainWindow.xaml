<Window x:Class="NavisLegacyPlugin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add-in Executed"
        Width="300"
        Height="150"
        WindowStartupLocation="CenterOwner">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!-- Status text -->
		<TextBlock
            Text="{Binding StatusText}"
            FontSize="14"
            TextWrapping="Wrap"
            VerticalAlignment="Center" />

		<!-- Buttons -->
		<StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">

			<TextBlock Text="{Binding DebugMarker}" />   

			<Button
                Content="Action One"
                Width="100"
                Margin="0,0,10,0"
                Command="{Binding ActionOneCommand}" />

			<Button
                Content="Action Two"
                Width="100"
                Command="{Binding ActionTwoCommand}" />
		</StackPanel>

		<StackPanel Margin="10">

			<CheckBox
                Content="Include sub-objects"
                IsChecked="{Binding GeometryPositions.IncludeSubObjects}" />

			<Button
                Content="Get Geometry Positions"
                Margin="0,10,0,10"
                Width="200"
                Command="{Binding GeometryPositions.RunCommand}" />

			<DataGrid
                ItemsSource="{Binding GeometryPositions.Results}"
                AutoGenerateColumns="False"
                Height="200">

				<DataGrid.Columns>
					<DataGridTextColumn Header="GUID"
                                Binding="{Binding ItemGuid}" />

					<DataGridTextColumn Header="Min"
                                Binding="{Binding BoundingBoxMin}" />

					<DataGridTextColumn Header="Max"
                                Binding="{Binding BoundingBoxMax}" />

					<DataGridTextColumn Header="Fragments"
                                Binding="{Binding FragmentCount}" />
				</DataGrid.Columns>

			</DataGrid>

		</StackPanel>


	</Grid>
</Window>