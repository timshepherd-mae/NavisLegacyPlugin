<Window x:Class="NavisLegacyPlugin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add-in Executed"
        Width="300"
        Height="150"
        WindowStartupLocation="CenterOwner">

	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- Controls -->
			<RowDefinition Height="*"/>
			<!-- DataGrid -->
		</Grid.RowDefinitions>

		<!-- Controls -->
		<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
			<CheckBox
            Content="Include sub-objects"
            IsChecked="{Binding GeometryPositions.IncludeSubObjects}" />

			<Button
            Content="Get Geometry Positions"
            Margin="10,0,0,0"
            Command="{Binding GeometryPositions.RunCommand}" />
		</StackPanel>

		<!-- Scrollable DataGrid -->
		<DataGrid
			x:Name="GeometryGrid"
            Grid.Row="1"
			SelectionChanged="GeometryGrid_SelectionChanged"
            ItemsSource="{Binding GeometryPositions.Results}"
            SelectedItem="{Binding GeometryPositions.SelectedRow, Mode=TwoWay}"
            AutoGenerateColumns="True"
            CanUserAddRows="False" />
	</Grid>

</Window>